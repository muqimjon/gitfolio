# GitHub Personal Access Token — classic, with NO scopes checked (public data only).
# Create one at https://github.com/settings/tokens
GH_TOKEN=

# Optional: extra tokens for rate-limit rotation. gitfolio uses PAT_1, PAT_2, ... in order.
# PAT_1=
# PAT_2=

# Optional: restrict which usernames this instance serves (comma-separated). Empty = anyone.
# WHITELIST=muqimjon

# Optional: force a cache TTL (seconds). Overrides the per-request min/max clamp.
# CACHE_SECONDS=
